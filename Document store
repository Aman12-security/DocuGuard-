"""
DocuGuard Document Store
JSON-based persistent storage for document fingerprints.
In production, replace with PostgreSQL/MongoDB.
"""

import json
import os
from pathlib import Path
from typing import Dict, Optional


class DocumentStore:
    """
    Local JSON-based document registry.
    Stores ONLY cryptographic fingerprints — never document content.
    """

    def __init__(self, db_path: str = "data/registry.json"):
        self.db_path = Path(db_path)
        self.db_path.parent.mkdir(parents=True, exist_ok=True)
        self._data = self._load()

    def _load(self) -> Dict:
        """Load registry from disk."""
        if self.db_path.exists():
            try:
                with open(self.db_path, 'r') as f:
                    return json.load(f)
            except (json.JSONDecodeError, IOError):
                return {}
        return {}

    def _save(self):
        """Save registry to disk."""
        with open(self.db_path, 'w') as f:
            json.dump(self._data, f, indent=2)

    def register(self, user_id: str, doc_id: str, record: Dict):
        """Register a document fingerprint."""
        if user_id not in self._data:
            self._data[user_id] = {}
        self._data[user_id][doc_id] = record
        self._save()

    def get_user_docs(self, user_id: str) -> Dict:
        """Get all documents for a user."""
        return self._data.get(user_id, {})

    def find_by_hash(self, sha256_hash: str) -> Optional[Dict]:
        """Find any document by its SHA-256 hash (across all users)."""
        for user_id, docs in self._data.items():
            for doc_id, record in docs.items():
                if record.get('sha256') == sha256_hash:
                    return record
        return None

    def find_by_doc_id(self, doc_id: str) -> Optional[Dict]:
        """Find document by its Document ID."""
        for user_id, docs in self._data.items():
            if doc_id in docs:
                return docs[doc_id]
        return None

    def find_by_filename(self, filename: str, user_id: str) -> Optional[Dict]:
        """Find a user's registered document by filename."""
        user_docs = self._data.get(user_id, {})
        for doc_id, record in user_docs.items():
            if record.get('file_name') == filename:
                return record
        return None

    def delete_doc(self, user_id: str, doc_id: str) -> bool:
        """Delete a document from the registry."""
        if user_id in self._data and doc_id in self._data[user_id]:
            del self._data[user_id][doc_id]
            self._save()
            return True
        return False

    def stats(self) -> Dict:
        """Global registry statistics."""
        total_users = len(self._data)
        total_docs = sum(len(docs) for docs in self._data.values())
        return {
            'total_users': total_users,
            'total_documents': total_docs
        }
